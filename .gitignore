# Rust / cargo
target/
**/target/
Cargo.lock.bak
**/build/
**/*.wasm

# wash + dev caches
.cache/
.wash/cache/

# Per-component fetched WIT deps (regenerated by `wkg wit fetch`).
# The source-of-truth lives at /wit/deps/ at the workspace root.
components/*/wit/deps/
components/*/wkg.lock

# Logs
*.log

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Node / Vite
node_modules/
ui/dist/
ui/.vite/
.pnpm-store/
tests/ui/.traces/
tests/ui/test-results/
tests/ui/playwright-report/

# SBOMs (regenerated by `make sbom`)
**/bom.cdx.json
.cache/sbom/
